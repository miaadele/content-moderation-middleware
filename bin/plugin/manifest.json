{
    "manifest_version": 3,
    "name": "Ascertion",
    "version": "1.0",
    "description": "SD plugin",
    "permissions": ["activeTab", "scripting", "downloads"],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["https://www.linkedin.com/*"],
            "js": ["popup.js"]
        }
    ]
}